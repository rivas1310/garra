# Configuración de SkyDropX
# Copia este archivo a .env y completa con tus credenciales

# Entorno (sandbox o production)
SKYDROPX_ENVIRONMENT=sandbox

# URL base de la API (opcional, se configura automáticamente según el entorno)
# SKYDROPX_API_URL=https://api-demo.skydropx.com

# Versión de la API (opcional, por defecto v1)
# SKYDROPX_API_VERSION=v1

# Método de autenticación Token API Key
SKYDROPX_API_KEY=tu_api_key_aqui

# Método de autenticación HMAC-SHA512
SKYDROPX_API_SECRET=tu_api_secret_aqui

# Método de autenticación OAuth2
SKYDROPX_CLIENT_ID=tu_client_id_aqui
SKYDROPX_CLIENT_SECRET=tu_client_secret_aqui

# Configuración de dirección de origen (para crear envíos)
ORIGIN_NAME="Nombre de Remitente"
ORIGIN_COMPANY="Nombre de Empresa"
ORIGIN_EMAIL="correo@ejemplo.com"
ORIGIN_PHONE="5555555555"
ORIGIN_STREET="Calle Principal"
ORIGIN_NUMBER="123"
ORIGIN_DISTRICT="Colonia"
ORIGIN_CITY="Ciudad"
ORIGIN_STATE="Estado"
ORIGIN_COUNTRY="MX"
ORIGIN_POSTAL_CODE="12345"

# === CONFIGURACIÓN DE ENVÍO CLICK ===
# API Key de Envío Click
ENVIOCLICK_API_KEY=tu_envio_click_api_key_aqui
# User-Agent para Envío Click
ENVIOCLICK_USER_AGENT=tu_envio_click_user_agent_aqui

# URLs de la API de Envío Click
# Nota: URLs actualizadas a la nueva versión de la API
ENVIOCLICK_API_URL=https://staging-api.envioclickpro.com/api/v2
ENVIOCLICK_PRODUCTION_URL=https://api.envioclickpro.com/api/v2
ENVIOCLICK_STAGING_URL=https://staging-api.envioclickpro.com/api/v2

# === CONFIGURACIÓN DE BASE DE DATOS ===
# URL de conexión a la base de datos
DATABASE_URL="postgresql://usuario:password@localhost:5432/bazar_db"

# === CONFIGURACIÓN DE AUTENTICACIÓN ===
# Secret para NextAuth.js
NEXTAUTH_SECRET=tu_nextauth_secret_muy_seguro_aqui
NEXTAUTH_URL=http://localhost:3000

# === CONFIGURACIÓN DE EMAIL ===
# Configuración SMTP para envío de emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASSWORD=tu_app_password_aqui

# === CONFIGURACIÓN DE CLOUDINARY ===
# Para manejo de imágenes
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# === CONFIGURACIÓN DE STRIPE ===
# Para procesamiento de pagos
STRIPE_PUBLISHABLE_KEY=pk_test_tu_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_tu_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_tu_webhook_secret

# === CONFIGURACIÓN DE DESARROLLO ===
# Puerto del servidor de desarrollo
PORT=3000

# Nivel de logging (error, warn, info, debug)
LOG_LEVEL=info